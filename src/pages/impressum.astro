---
import { getEntry, render } from 'astro:content'
import Layout from "../layouts/Layout.astro"

const page = await getEntry('pages', 'impressum')
const { Content } = await render(page)
---

<Layout title={page.data.title}>
  <section class="max-w-[92vw] lg:max-w-4xl mx-auto bs-mt-md px-5 py-8 md:p-20 flex flex-col gap-3 justify-between border rounded-md bg-bs-surface-2 border-bs-surface-3 [&_a]:underline [&_a]:underline-offset-4 [&_a]:decoration-bs-foreground-dark/80 [&_a]:hover:decoration-bs-foreground-light">
    <h1 class="bs-h1">{page.data.title}</h1>
    <div class="prose prose-invert bs-mt-sm">
      <Content />
    </div>
  </section>
</Layout>